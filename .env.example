# ─── Database (DB terpisah dari portal) ────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=meetrip_db
DB_USER=postgres
DB_PASSWORD=your_secure_password

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=3003
HOST=0.0.0.0
NODE_ENV=development

# ─── JWT (session MeeTrip sendiri) ─────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_at_least_32_characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── INL Portal SSO Provider ───────────────────────────────────────────────────
PORTAL_API_URL=http://127.0.0.1:3001

# ─── Google Maps API (reverse geocode wilayah_tipe) ───────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Attend Stamp ──────────────────────────────────────────────────────────────
# Default radius toleransi attend stamp (meter). Bisa diubah lewat config admin
ATTEND_RADIUS_METER=500

# ─── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
UPLOAD_URL=http://localhost:3003/uploads
UPLOAD_MAX_SIZE_MB=10
